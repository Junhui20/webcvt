{
  "name": "@catlabtech/webcvt-cli",
  "version": "0.1.0",
  "description": "Command-line interface for webcvt — thin shell around @catlabtech/webcvt-core",
  "type": "module",
  "bin": {
    "webcvt": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "files": ["dist"],
  "scripts": {
    "build": "tsup && node -e \"require('node:fs').chmodSync('dist/cli.js', 0o755)\"",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@catlabtech/webcvt-core": "workspace:*"
  },
  "optionalDependencies": {
    "@catlabtech/webcvt-container-mp3": "workspace:*",
    "@catlabtech/webcvt-container-wav": "workspace:*",
    "@catlabtech/webcvt-container-flac": "workspace:*",
    "@catlabtech/webcvt-container-ogg": "workspace:*",
    "@catlabtech/webcvt-container-aac": "workspace:*",
    "@catlabtech/webcvt-container-mp4": "workspace:*",
    "@catlabtech/webcvt-container-webm": "workspace:*",
    "@catlabtech/webcvt-container-mkv": "workspace:*",
    "@catlabtech/webcvt-container-ts": "workspace:*",
    "@catlabtech/webcvt-image-canvas": "workspace:*",
    "@catlabtech/webcvt-image-svg": "workspace:*",
    "@catlabtech/webcvt-image-animation": "workspace:*",
    "@catlabtech/webcvt-image-legacy": "workspace:*",
    "@catlabtech/webcvt-data-text": "workspace:*",
    "@catlabtech/webcvt-archive-zip": "workspace:*",
    "@catlabtech/webcvt-subtitle": "workspace:*",
    "@catlabtech/webcvt-backend-wasm": "workspace:*"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "tsup": "^8.3.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
